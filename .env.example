# =============================================================================
# AI PathFinder — Root Environment Variables
# Copy this file to `.env` in the project root and fill in your values.
# Backend also reads `backend/.env` (overrides root for backend-specific vars).
# =============================================================================

# Server
PORT=8080
PUBLIC_API_URL=http://localhost:8080

# Database (PostgreSQL)
# Local Docker: postgresql://aipathfinder:aipathfinder@localhost:5432/aipathfinder
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Authentication
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRES_IN=7d

# CORS & Frontend
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:5174
VITE_BASE_URL=http://localhost:8080

# AI Service (Python Flask microservice)
AI_SERVICE_URL=http://127.0.0.1:5000/ai

# AI Provider API Keys (at least one required for AI features)
OPENAI_API_KEY=sk-your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key

# Email (optional — for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com

# Alternative email provider (optional)
# RESEND_API_KEY=your-resend-api-key
